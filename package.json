{
  "name": "webos-iptv-player",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "package": "bash build.sh",
    "clean": "rm -rf dist *.ipk",
    "preview": "npm run build && node serve.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "hls.js": "^1.6.15",
    "mpegts.js": "^1.8.0"
  }
}
